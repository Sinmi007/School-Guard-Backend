# --- Application ---
PORT=3000
NODE_ENV=production

# --- Database (PostgreSQL) ---
# On Railway this is injected automatically via the PostgreSQL plugin.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/schoolguard?schema=public"

# --- Auth ---
# Generate a strong secret, e.g. `openssl rand -base64 48`
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"
